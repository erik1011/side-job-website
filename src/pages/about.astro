---
import BaseLayout from '../layouts/BaseLayout.astro';
import GradientBg from '../components/ui/GradientBg.astro';
import Card from '../components/ui/Card.astro';
import { getTranslations } from '../utils/i18n';

const lang = 'zh';
const t = getTranslations(lang);
const featureIcons = ['📷', '🤖', '🖼️', '✨', '⚡', '☁️'];
---

<BaseLayout title={t.about.title} lang={lang}>
  <section class="relative min-h-[60vh] flex items-center pt-20 overflow-hidden">
    <GradientBg />
    <div class="container-custom relative z-10">
      <div class="page-hero-content max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">{t.about.hero.title}</h1>
        <p class="text-xl text-gray-400 mb-8 leading-relaxed">{t.about.hero.subtitle}</p>
        <a href="#" class="btn-primary">{t.about.hero.cta}</a>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-custom max-w-4xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-8">{t.about.mission.title}</h2>
      <p class="text-gray-400 text-lg leading-relaxed">{t.about.mission.content}</p>
    </div>
  </section>

  <section class="section-padding bg-white/5">
    <div class="container-custom">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-16">{t.about.features.title}</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {t.about.features.items.map((item, i) => (
          <Card>
            <span class="text-4xl mb-4 block">{featureIcons[i]}</span>
            <h3 class="text-xl font-bold mb-2">{item.title}</h3>
            <p class="text-gray-400 text-sm">{item.description}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-custom max-w-4xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-8">{t.about.story.title}</h2>
      <p class="text-gray-400 text-lg leading-relaxed">{t.about.story.content}</p>
    </div>
  </section>
</BaseLayout>

<script>
  import { initScrollAnimations } from '../scripts/hero-animation';
  initScrollAnimations();
</script>
