---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  class?: string;
}

const { href = '#', variant = 'primary', class: className = '' } = Astro.props;
const baseClass = variant === 'primary' ? 'btn-primary' : 'btn-secondary';
---

<a href={href} class:list={[baseClass, className]}>
  <slot />
</a>
