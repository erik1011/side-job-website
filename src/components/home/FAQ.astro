---
import type { Lang } from '../../i18n/ui';
import { getTranslations } from '../../utils/i18n';

interface Props {
  lang: Lang;
  items?: { question: string; answer: string }[];
  title?: string;
  subtitle?: string;
}

const { lang, items, title, subtitle } = Astro.props;
const t = getTranslations(lang);
const faqItems = items ?? t.faq.items;
const faqTitle = title ?? t.faq.title;
const faqSubtitle = subtitle ?? t.faq.subtitle;
---

<section class="faq-section section-padding relative">
  <div class="container-custom max-w-3xl">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">{faqTitle}</h2>
      {faqSubtitle && <p class="text-gray-400 text-lg">{faqSubtitle}</p>}
    </div>

    <div class="space-y-4">
      {faqItems.map((item) => (
        <div class="faq-item glass rounded-2xl overflow-hidden">
          <button class="faq-question w-full flex items-center justify-between p-6 text-left hover:bg-white/5 transition-colors">
            <span class="font-medium text-white pr-4">{item.question}</span>
            <svg class="faq-icon w-5 h-5 text-accent-cyan flex-shrink-0 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
          <div class="faq-answer h-0 overflow-hidden">
            <p class="px-6 pb-6 text-gray-400 leading-relaxed">{item.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { initFAQAccordion } from '../../scripts/hero-animation';
  initFAQAccordion();
</script>
