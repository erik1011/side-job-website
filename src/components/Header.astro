---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { siteConfig } from '../config/site';
import { withBase } from '../utils/assets';
import { getTranslations } from '../utils/i18n';
import { navItems, type Lang } from '../i18n/ui';
import LangSwitch from './LangSwitch.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const currentPath = Astro.url.pathname;

function isActive(path: string): boolean {
  const localizedPath = getRelativeLocaleUrl(lang, path);
  if (path === '/') {
    return currentPath === localizedPath || currentPath === `${localizedPath}`;
  }
  return currentPath.includes(path === '/' ? '' : path);
}
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav class="container-custom">
    <div class="flex items-center justify-between h-16 md:h-20">
      <a
        href={getRelativeLocaleUrl(lang, '/')}
        class="flex items-center gap-2 text-xl font-bold text-white hover:opacity-90 transition-opacity"
        aria-label={siteConfig.name}
      >
        <img
          src={withBase(siteConfig.logo)}
          alt=""
          class="w-8 h-8 rounded-full object-cover"
          width="32"
          height="32"
        />
        <span>{siteConfig.name}</span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-8">
        {navItems.map((item) => (
          <a
            href={getRelativeLocaleUrl(lang, item.path)}
            class:list={[
              'text-sm font-medium transition-colors hover:text-accent-cyan',
              isActive(item.path) ? 'text-accent-cyan' : 'text-gray-300',
            ]}
          >
            {t.nav[item.key.split('.')[1] as keyof typeof t.nav]}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-4">
        <LangSwitch lang={lang} />
        <a href="#" class="hidden sm:inline-flex btn-primary text-sm px-6 py-2">
          {siteConfig.cta[lang]}
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-gray-300 hover:text-white"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            <path id="menu-icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-2">
        {navItems.map((item) => (
          <a
            href={getRelativeLocaleUrl(lang, item.path)}
            class:list={[
              'px-4 py-3 rounded-lg text-sm font-medium transition-colors',
              isActive(item.path)
                ? 'bg-white/10 text-accent-cyan'
                : 'text-gray-300 hover:bg-white/5',
            ]}
          >
            {t.nav[item.key.split('.')[1] as keyof typeof t.nav]}
          </a>
        ))}
        <a href="#" class="mx-4 mt-2 btn-primary text-sm text-center">
          {siteConfig.cta[lang]}
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById('site-header');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  window.addEventListener('scroll', () => {
    if (!header) return;
    if (window.scrollY > 20) {
      header.classList.add('glass', 'shadow-lg');
    } else {
      header.classList.remove('glass', 'shadow-lg');
    }
  });

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false;
    menuBtn.setAttribute('aria-expanded', String(isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });
</script>
