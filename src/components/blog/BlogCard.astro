---
import { getRelativeLocaleUrl } from 'astro:i18n';
import Card from '../ui/Card.astro';
import { withBase } from '../../utils/assets';
import type { BlogPost } from '../../data/blog-posts';
import type { Lang } from '../../i18n/ui';

interface Props {
  post: BlogPost;
  lang: Lang;
  readMore: string;
}

const { post, lang, readMore } = Astro.props;
const localized = post[lang];
const href = getRelativeLocaleUrl(lang, `/blog/${post.slug}`);
---

<a href={href} class="block group">
  <Card class="overflow-hidden !p-0 h-full">
    <div class="aspect-video overflow-hidden bg-dark-lighter">
      <img
        src={withBase(post.image)}
        alt=""
        class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
        loading="lazy"
        width="400"
        height="225"
      />
    </div>
    <div class="p-6">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-xs text-accent-cyan font-medium">{localized.category}</span>
        <span class="text-xs text-gray-500">{post.date}</span>
      </div>
      <h3 class="text-lg font-bold mb-2 group-hover:text-accent-cyan transition-colors">{localized.title}</h3>
      <p class="text-gray-400 text-sm mb-4 line-clamp-2">{localized.excerpt}</p>
      <span class="text-accent-cyan text-sm font-medium group-hover:underline">{readMore} →</span>
    </div>
  </Card>
</a>
